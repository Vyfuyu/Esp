getgenv().Running = true

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local CollectionService = game:GetService("CollectionService")

local Loader = require(ReplicatedStorage.Packages.Loader)
local ReplicaController = require(Loader.Shared.Utility.ReplicaController)
local BooksData = require(Loader.Shared.Data.Books)

--// WAIT LIBRARY REPLICA SAFE
local LibraryReplica
for _, r in pairs(ReplicaController._replicas) do
    if r.Class == "Library" then
        LibraryReplica = r
        break
    end
end

if not LibraryReplica then
    ReplicaController.ReplicaOfClassCreated("Library", function(rep)
        LibraryReplica = rep
    end)

    repeat task.wait() until LibraryReplica
end

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")

local Library = Workspace:WaitForChild("Library")
local BooksFolder = Library:WaitForChild("Books")

--// CAMERA FIX (stable hơn)
player.CameraMode = Enum.CameraMode.Classic
task.defer(function()
    task.wait(0.2)
    player.CameraMinZoomDistance = 0.5
end)

--// CACHE SHELVES
local shelfModels = {}
for _, v in ipairs(CollectionService:GetTagged("Shelf")) do
    shelfModels[v.Name] = v
end

--// TRACKED BOOKS (tránh xử lý lại)
local processed = {}

local function teleport(pos)
    if not root then return end
    root.CFrame = CFrame.new(pos + Vector3.new(0, 2, 0))
    task.wait(0.12)
end

local function getSeries(shelfId)
    local data = LibraryReplica.Data.Shelves[shelfId]
    if not data then return nil end

    for _, b in pairs(data.Books) do
        local name = typeof(b) == "Instance" and b.Name or b
        local series = name:match("^(.-)_(.+)$")
        if series then return series end
    end
end

local function findShelf(series, genre, count)
    for id, data in pairs(LibraryReplica.Data.Shelves) do
        if not data.Completed and data.Category == genre then
            local shelf = shelfModels[id]
            if shelf and shelf:GetAttribute("Width") == count then
                if getSeries(id) == series then
                    return shelf, id
                end
            end
        end
    end

    for id, data in pairs(LibraryReplica.Data.Shelves) do
        if not data.Completed and data.Category == genre then
            local shelf = shelfModels[id]
            if shelf and shelf:GetAttribute("Width") == count then
                if not getSeries(id) and next(data.Books) == nil then
                    return shelf, id
                end
            end
        end
    end
end

local function safeFire(action, ...)
    local args = {...}
    for i = 1, 2 do
        local ok = pcall(function()
            LibraryReplica:FireServer(action, table.unpack(args))
        end)
        if ok then return true end
        task.wait(0.1)
    end
    return false
end

task.spawn(function()
    for _, book in ipairs(BooksFolder:GetChildren()) do
        if not getgenv().Running then break end

        if processed[book] then continue end

        local series, vol = book.Name:match("^(.-)_(.+)$")
        local volNum = tonumber(vol)

        if series and volNum then
            local genre, info = BooksData.GetCategory(series)

            if genre and info then
                local shelf = findShelf(series, genre, info.VolumeCount)

                if shelf then
                    local shelfData = LibraryReplica.Data.Shelves[shelf.Name]

                    if not (shelfData and shelfData.Books[tostring(volNum)]) then
                        processed[book] = true

                        teleport(book:GetPivot().Position)
                        safeFire("Grab", book)

                        task.wait(0.15)

                        teleport(shelf:GetPivot().Position)
                        safeFire("Place", shelf, volNum - 1)

                        task.wait(0.25)
                    end
                end
            end
        end

        task.wait(0.03)
    end

    getgenv().Running = false
end)
