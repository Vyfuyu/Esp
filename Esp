Title.TextSize = 14
Title.Parent = MainFrame

-- Nút Bật/Tắt (Toggle Button)
local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Name = "ToggleBtn"
ToggleBtn.Size = UDim2.new(0, 140, 0, 40)
ToggleBtn.Position = UDim2.new(0.5, -70, 0.5, -5)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đỏ (Đang tắt)
ToggleBtn.Text = "AUTO TP: OFF"
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.TextSize = 16
ToggleBtn.Parent = MainFrame

-- Bo góc cho Nút
local BtnCorner = Instance.new("UICorner")
BtnCorner.CornerRadius = UDim.new(0, 6)
BtnCorner.Parent = ToggleBtn

-- 4. Logic Xử Lý Dịch Chuyển (Teleport Logic)
local function startTeleportLoop()
    task.spawn(function()
        while isLooping do
            local allPlayers = Players:GetPlayers()
            local teleportedAny = false

            for _, targetPlayer in ipairs(allPlayers) do
                -- Kiểm tra nếu vòng lặp bị tắt đột ngột
                if not isLooping then break end

                -- Không tự dịch chuyển đến chính mình và kiểm tra người chơi hợp lệ
                if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local myChar = getCharacter()
                    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

                    if targetRoot and myRoot then
                        -- Tiến hành dịch chuyển ra phía trên đầu mục tiêu một chút (tránh kẹt đất)
                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 2, 0)
                        teleportedAny = true
                        task.wait(teleportCooldown)
                    end
                end
            end

            -- Nếu trong server không có ai khác, đợi 1 giây rồi quét lại
            if not teleportedAny then
                task.wait(1)
            end
        end
    end)
end

-- 5. Lắng nghe sự kiện click nút
ToggleBtn.MouseButton1Click:Connect(function()
    isLooping = not isLooping
    
    if isLooping then
        -- Trạng thái BẬT
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 180, 50)}):Play()
        ToggleBtn.Text = "AUTO TP: ON"
        startTeleportLoop()
    else
        -- Trạng thái TẮT
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
        ToggleBtn.Text = "AUTO TP: OFF"
    end
end)
