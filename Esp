-- Tạo hiệu ứng kéo thả nút trên màn hình (để bạn thích dời đi đâu thì dời)
local UserInputService = game:GetService("UserInputService")
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleButton.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Sự kiện khi bấm vào nút
ToggleButton.MouseButton1Click:Connect(function()
    _G.AutoFarmEnabled = not _G.AutoFarmEnabled
    if _G.AutoFarmEnabled then
        ToggleButton.Text = "AUTO: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- Xanh lá
        print("🚀 [Auto-Farm]: ĐÃ BẬT")
    else
        ToggleButton.Text = "AUTO: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60) -- Đỏ
        print("🛑 [Auto-Farm]: ĐÃ TẮT")
    end
end)

----------------------------------------------------------------
-- LOGIC: LOGIC QUÉT VÀ TELEPORT QUẢ CẦU
----------------------------------------------------------------
local function isOrb(object)
    if object:IsA("BasePart") and not object:IsDescendantOf(LocalPlayer.Character) then
        local nameLower = string.lower(object.Name)
        if nameLower ~= "baseplate" and nameLower ~= "terrain" and nameLower ~= "field" and object.CanTouch == true then
            if object:FindFirstChildOfClass("TouchTransmitter") or object.Parent.Name:match("Orb") or object.Name:match("Orb") or object.Name:match("Star") then
                return true
            end
        end
    end
    return false
end

local function getClosestOrb()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local closestOrb = nil
    local shortestDistance = math.huge

    for _, object in ipairs(Workspace:GetDescendants()) do
        if isOrb(object) then
            local distance = (hrp.Position - object.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestOrb = object
            end
        end
    end
    return closestOrb
end

-- Vòng lặp chính
task.spawn(function()
    while true do
        task.wait(0.05)
        
        -- Chỉ chạy khi biến trạng thái đang là TRUE (ON)
        if _G.AutoFarmEnabled then
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if hrp and humanoid and humanoid.Health > 0 then
                local targetOrb = getClosestOrb()
                
                if targetOrb and targetOrb:IsDescendantOf(Workspace) then
                    hrp.CFrame = targetOrb.CFrame
                    local startTime = os.clock()
                    repeat 
                        task.wait() 
                    until not targetOrb:IsDescendantOf(Workspace) or (os.clock() - startTime > 0.2) or not _G.AutoFarmEnabled
                end
            end
        end
    end
end)

-- Đón đầu các quả cầu vừa mới spam
Workspace.DescendantAdded:Connect(function(descendant)
    if not _G.AutoFarmEnabled then return end
    
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if hrp and isOrb(descendant) then
        task.wait(0.02)
        if descendant:IsA("BasePart") and descendant:IsDescendantOf(Workspace) and _G.AutoFarmEnabled then
            hrp.CFrame = descendant.CFrame
        end
    end
end)
