local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

-- Biến trạng thái (Mặc định là BẬT khi mới chạy script)
_G.BlinkFarmEnabled = true
local MaxDistance = 250 -- Bán kính quét quả cầu xung quanh bạn

----------------------------------------------------------------
-- UI: TẠO NÚT ON/OFF NHỎ GỌN TRÊN MÀN HÌNH
----------------------------------------------------------------
if CoreGui:FindFirstChild("BlinkFarmGui") then
    CoreGui.BlinkFarmGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "BlinkFarmGui"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

local ToggleButton = Instance.new("TextButton")
ToggleButton.Name = "ToggleButton"
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 65, 0, 30)
ToggleButton.Position = UDim2.new(0, 10, 0, 50) -- Vị trí góc trên bên trái
ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- Màu xanh lá
ToggleButton.Text = "BLINK: ON"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 13

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 6)
UICorner.Parent = ToggleButton

-- Tạo hiệu ứng kéo thả nút di chuyển tự do trên màn hình
local UserInputService = game:GetService("UserInputService")
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- Sự kiện Bật/Tắt khi ấn nút
ToggleButton.MouseButton1Click:Connect(function()
    _G.BlinkFarmEnabled = not _G.BlinkFarmEnabled
    if _G.BlinkFarmEnabled then
        ToggleButton.Text = "BLINK: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        print(" [Blink-Farm]: ĐÃ BẬT")
    else
        ToggleButton.Text = "BLINK: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        print(" [Blink-Farm]: ĐÃ TẮT")
    end
end)

----------------------------------------------------------------
-- LOGIC: CHẠY LIÊN TỤC QUÉT VÀ ĂN QUẢ CẦU
----------------------------------------------------------------
local function isOrb(object)
    if object:IsA("BasePart") and not object:IsDescendantOf(LocalPlayer.Character) then
        local nameLower = string.lower(object.Name)
        if nameLower ~= "baseplate" and nameLower ~= "terrain" and nameLower ~= "field" and object.CanTouch == true then
            if object:FindFirstChildOfClass("TouchTransmitter") or object.Parent.Name:match("Orb") or object.Name:match("Orb") or object.Name:match("Star") then
                return true
            end
        end
    end
    return false
end

-- Vòng lặp chính quét liên tục
task.spawn(function()
    print(" [Blink-Farm]: Hệ thống quét liên tục đã bắt đầu!")
    while true do
        task.wait(0.01) -- Đặt độ trễ cực thấp để chạy liên tục không ngừng nghỉ
        
        if _G.BlinkFarmEnabled then
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if hrp and humanoid and humanoid.Health > 0 then
                -- Ghi nhớ vị trí bạn đang đứng yên ban đầu
                local originalCFrame = hrp.CFrame
                
                -- Duyệt và ăn cuốn chiếu các quả cầu tìm thấy
                for _, object in ipairs(Workspace:GetDescendants()) do
                    if not _G.BlinkFarmEnabled then break end -- Dừng ngay nếu bấm nút OFF
                    
                    if isOrb(object) and object:IsDescendantOf(Workspace) then
                        local distance = (originalCFrame.Position - object.Position).Magnitude
                        
                        if distance <= MaxDistance then
                            -- Tốc biến đến lụm -> Về lại chỗ cũ ngay lập tức (0.01s)
                            hrp.CFrame = object.CFrame
                            task.wait(0.01)
                            hrp.CFrame = originalCFrame
                            
                            -- Chờ một nhịp siêu ngắn để game kịp xóa quả cầu cũ và tránh quá tải cấu hình
                            task.wait(0.01)
                        end
                    end
                end
            end
        end
    end
end)
