-- 1. Custom Speed (Bật/Tắt & Tùy chỉnh tốc độ)
createToggle("Tùy Chỉnh Tốc Độ", UDim2.new(0, 20, 0, 60), function(val)
    Settings.SpeedEnabled = val
end)

createSlider(UDim2.new(0, 20, 0, 105), function(val)
    Settings.WalkSpeed = val
end)

RunService.Heartbeat:Connect(function()
    if Settings.SpeedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Settings.WalkSpeed
    elseif not Settings.SpeedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = 16 -- Tốc độ mặc định
    end
end)

-- 2. Noclip Xuyên Tường
createToggle("Noclip Xuyên Tường", UDim2.new(0, 20, 0, 150), function(val)
    Settings.NoclipEnabled = val
end)

RunService.Stepped:Connect(function()
    if Settings.NoclipEnabled and LocalPlayer.Character then
        for _, part in pairs(LocalPlayer.Character:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- 3. Smart ESP Phân Tích (Hiển thị tên, Khoảng cách & Box)
createToggle("Định Vị ESP Người Chơi", UDim2.new(0, 20, 0, 195), function(val)
    Settings.EspEnabled = val
    if not val then
        -- Xóa ESP khi tắt
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Highlight") then
                p.Character.Highlight:Destroy()
            end
            if p.Character and p.Character:FindFirstChild("ESP_Billboard") then
                p.Character.ESP_Billboard:Destroy()
            end
        end
    end
end)

local function applyESP(player)
    if player == LocalPlayer then return end
    
    RunService.RenderStepped:Connect(function()
        if not Settings.EspEnabled then return end
        
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            -- Tạo Highlight (Khung nhìn xuyên tường thông minh)
            if not char:FindFirstChild("Highlight") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "Highlight"
                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.OutlineTransparency = 0
                highlight.Parent = char
            end
            
            -- Tính khoảng cách và phân tích
            local distance = math.floor((LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude) or 0)
            
            -- Tạo Tag thông tin (Tên + Khoảng cách)
            local billboard = char:FindFirstChild("ESP_Billboard")
            if not billboard then
                billboard = Instance.new("BillboardGui")
                billboard.Name = "ESP_Billboard"
                billboard.AlwaysOnTop = true
                billboard.Size = UDim2.new(0, 200, 0, 50)
                billboard.StudsOffset = Vector3.new(0, 3, 0)
                
                local label = Instance.new("TextLabel")
                label.Name = "InfoLabel"
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.TextColor3 = Color3.fromRGB(255, 255, 0)
                label.TextSize = 12
                label.Font = Enum.Font.SourceSansBold
                label.Parent = billboard
                
                billboard.Parent = char
            end
            
            -- Cập nhật text thời gian thực (Thông minh: Đổi màu theo khoảng cách nguy hiểm)
            local label = billboard:FindFirstChild("InfoLabel")
            if label then
                label.Text = string.format("%s\n[%dm] - HP: %d", player.Name, distance, math.floor(char.Humanoid.Health))
                if distance < 50 then
                    label.TextColor3 = Color3.fromRGB(255, 50, 50) -- Gần (Nguy hiểm) -> Đỏ
                else
                    label.TextColor3 = Color3.fromRGB(50, 255, 50) -- Xa -> Xanh
                end
            end
        else
            -- Xóa nếu người chơi chết hoặc mất nhân vật
            if char and char:FindFirstChild("Highlight") then char.Highlight:Destroy() end
            if char and char:FindFirstChild("ESP_Billboard") then char.ESP_Billboard:Destroy() end
        end
    end)
end

-- Kích hoạt ESP cho người chơi hiện tại và người mới vào phòng
for _, p in pairs(Players:GetPlayers()) do applyESP(p) end
Players.PlayerAdded:Connect(applyESP)
