local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-bots/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-bots/Fluent/master/Addons/InterfaceManager.lua"))()

local Window = Fluent:CreateWindow({
