local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print(" [Auto-Farm]: Đang quét các quả cầu trên sân... Đã kích hoạt!")

-- Hàm kiểm tra xem một Part có phải là quả cầu nhặt được không
local function isOrb(object)
    if object:IsA("BasePart") and not object:IsDescendantOf(LocalPlayer.Character) then
        -- Loại bỏ các object không phải vật phẩm (sân cỏ, khán đài, baseplate...)
        local nameLower = string.lower(object.Name)
        if nameLower ~= "baseplate" and nameLower ~= "terrain" and nameLower ~= "field" and object.CanTouch == true then
            -- Thường quả cầu nhặt sẽ có TouchTransmitter (vùng chạm) hoặc nằm trong Folder riêng
            if object:FindFirstChildOfClass("TouchTransmitter") or object.Parent.Name:match("Orb") or object.Name:match("Orb") or object.Name:match("Star") then
                return true
            end
        end
    end
    return false
end

-- Hàm tìm quả cầu gần nhất hiện tại
local function getClosestOrb()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local closestOrb = nil
    local shortestDistance = math.huge

    -- Quét toàn bộ Workspace để tìm quả cầu
    for _, object in ipairs(Workspace:GetDescendants()) do
        if isOrb(object) then
            local distance = (hrp.Position - object.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestOrb = object
            end
        end
    end
    return closestOrb
end

-- Vòng lặp Teleport chính
task.spawn(function()
    while true do
        task.wait(0.05) -- Tốc độ quét cực nhanh (0.05 giây một lần)
        
        local character = LocalPlayer.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        
        if hrp and humanoid and humanoid.Health > 0 then
            local targetOrb = getClosestOrb()
            
            if targetOrb and targetOrb:IsDescendantOf(Workspace) then
                -- Dịch chuyển tức thời đến tọa độ quả cầu
                hrp.CFrame = targetOrb.CFrame
                
                -- Đợi một chút cực ngắn để game kịp nhận va chạm nhặt quả cầu
                local startTime = os.clock()
                repeat 
                    task.wait() 
                until not targetOrb:IsDescendantOf(Workspace) or (os.clock() - startTime > 0.2)
            end
        end
    end
end)

-- BẮT KHÍ PHÁT SINH: Nếu có quả cầu mới spam ra, ưu tiên xử lý ngay
Workspace.DescendantAdded:Connect(function(descendant)
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if hrp and isOrb(descendant) then
        -- Quả cầu mới vừa xuất hiện -> Tele thẳng tới luôn
        task.wait(0.02) -- Chờ nó ổn định vị trí trên sân
        if descendant:IsA("BasePart") and descendant:IsDescendantOf(Workspace) then
            hrp.CFrame = descendant.CFrame
        end
    end
end)
