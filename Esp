local Tabs = {
    Main = Window:AddTab({ Title = "Tính năng chính", Icon = "user" }),
    Settings = Window:AddTab({ Title = "Cài đặt", Icon = "settings" })
}

-- Khởi tạo biến cấu hình
local Config = {
    Speed = 16,
    Noclip = false,
    ESP = false
}

-- SERVICE
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-------------------------------------------------------------------------------
-- CHỨC NĂNG 1: ESP (Định vị người chơi)
-------------------------------------------------------------------------------
local espHighlights = {}

local function createESP(player)
    if player == LocalPlayer then return end
    
    local function applyESP(character)
        if not character then return end
        
        -- Chờ RootPart xuất hiện
        character:WaitForChild("HumanoidRootPart", 5)
        
        -- Tạo Highlight (Hiệu ứng viền xuyên tường)
        if not character:FindFirstChild("ESPHighlight") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESPHighlight"
            highlight.Adornee = character
            highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Màu đỏ trong suốt
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng
            highlight.OutlineTransparency = 0
            highlight.Enabled = Config.ESP
            highlight.Parent = character
            
            espHighlights[player.UserId] = highlight
        end
    end
    
    player.CharacterAdded:Connect(applyESP)
    if player.Character then applyESP(player.Character) end
end

-- Tải ESP cho người chơi hiện tại và người mới vào
for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

-- Xóa dữ liệu khi người chơi thoát
Players.PlayerRemoving:Connect(function(player)
    if espHighlights[player.UserId] then
        espHighlights[player.UserId] = nil
    end
end)

-------------------------------------------------------------------------------
-- CHỨC NĂNG 2 & 3: SPEED & NOCLIP
-------------------------------------------------------------------------------
-- Vòng lặp xử lý Speed và Noclip liên tục để tránh bị game reset
RunService.Stepped:Connect(function()
    local character = LocalPlayer.Character
    if not character then return end
    
    -- Xử lý Speed
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = Config.Speed
    end
    
    -- Xử lý Noclip (Xuyên tường)
    if Config.Noclip then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end)

-------------------------------------------------------------------------------
-- GIAO DIỆN MENU (UI CONTROLS)
-------------------------------------------------------------------------------

-- 1. Bật/Tắt ESP
Tabs.Main:AddToggle("ESPToggle", {
    Title = "Bật Định Vị (ESP)",
    Default = false,
    Callback = function(Value)
        Config.ESP = Value
        for _, highlight in pairs(espHighlights) do
            if highlight then
                highlight.Enabled = Value
            end
        end
    end
})

-- 2. Bật/Tắt Noclip
Tabs.Main:AddToggle("NoclipToggle", {
    Title = "Xuyên tường (Noclip)",
    Default = false,
    Callback = function(Value)
        Config.Noclip = Value
    end
})

-- 3. Tùy chỉnh Tốc độ (Speed)
local SpeedSlider = Tabs.Main:AddSlider("SpeedSlider", {
