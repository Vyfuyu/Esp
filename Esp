-- Hàm tạo ESP thông minh cho từng Player
local function CreateESP(Player)
    if Player == LocalPlayer then return end

    local BoxHighlight = Instance.new("Highlight")
    BoxHighlight.Name = "SmartESP_" .. Player.Name
    BoxHighlight.FillTransparency = 0.5
    BoxHighlight.OutlineTransparency = 0
    BoxHighlight.Adornee = nil
    BoxHighlight.Parent = game:GetService("CoreGui") -- Tránh bị xóa bởi game

    -- Cập nhật logic ESP theo thời gian thực
    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not Settings.ESPEnabled or not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then
            BoxHighlight.Adornee = nil
            return
        end

        -- Phân biệt màu sắc theo Team (Thông minh)
        if Player.Team ~= LocalPlayer.Team then
            BoxHighlight.FillColor = Color3.fromRGB(255, 0, 0) -- Địch: Đỏ
            BoxHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        else
            BoxHighlight.FillColor = Color3.fromRGB(0, 255, 0) -- Đồng đội: Xanh lá
            BoxHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end

        BoxHighlight.Adornee = Player.Character
    end)

    -- Dọn dẹp bộ nhớ khi player thoát để tránh lag Mobile
    Player.AncestryChanged:Connect(function()
        if not Player:IsDescendantOf(Players) then
            BoxHighlight:Destroy()
            if Connection then Connection:Disconnect() end
        end
    end)
end

-- Áp dụng ESP cho người chơi hiện tại và người mới vào
for _, player in pairs(Players:GetPlayers()) do
    CreateESP(player)
end
Players.PlayerAdded:Connect(CreateESP)

