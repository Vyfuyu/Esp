--[[
    ========================================================================
    🔥 ADVANCED LIBRARY AUTO-FARM (INSTANT QUEUE & FAKE POSITION BYPASS) 🔥
    ========================================================================
    Tính năng nâng cấp:
    1. Instant Queue: Xử lý song song tất cả các sách cùng lúc bằng luồng độc lập.
    2. No Teleport Visible: Gửi vị trí đến mục tiêu rồi thu hồi về vị trí cũ 
       ngay lập tức, giảm thiểu tối đa việc người khác nhìn thấy bạn bay khắp map.
    3. Auto Refresh: Tự động cập nhật RootPart khi nhân vật hồi sinh/reset.
    4. Loop AFK 24/7: Tự động nhặt tiếp khi có sách mới rơi ra.
]]

getgenv().Running = true

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local CollectionService = game:GetService("CollectionService")

local Loader = require(ReplicatedStorage.Packages.Loader)
local ReplicaController = require(Loader.Shared.Utility.ReplicaController)
local BooksData = require(Loader.Shared.Data.Books)

-- 1. CHỜ REPLICA CONTROLLER LOAD XONG
local LibraryReplica
for _, r in pairs(ReplicaController._replicas) do
    if r.Class == "Library" then
        LibraryReplica = r
        break
    end
end

if not LibraryReplica then
    ReplicaController.ReplicaOfClassCreated("Library", function(r)
        LibraryReplica = r
    end)
    repeat task.wait() until LibraryReplica
end

local player = Players.LocalPlayer

-- 2. ĐẢM BẢO NHÂN VẬT LUÔN ĐƯỢC CẬP NHẬT (ANTI-BUG KHI CHẾT/RESET)
local function getRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart", 5)
end

local BooksFolder = Workspace.Library:WaitForChild("Books")

-- 3. CACHE KỆ SÁCH ĐỂ TRA CỨU SIÊU TỐC
local shelves = {}
for _, s in ipairs(CollectionService:GetTagged("Shelf")) do
    shelves[s.Name] = s
end

local shelfDataCache = LibraryReplica.Data.Shelves

-- 4. FAKE POSITION BYPASS (Dịch chuyển ẩn danh, giật về vị trí cũ lập tức)
local function executeAtPosition(targetPos, actionCallback)
    local root = getRoot()
    if not root then return end

    -- Lưu lại vị trí đứng an toàn ban đầu của bạn (Ví dụ: Bạn đang đứng trốn ở góc tường)
    local originalCFrame = root.CFrame

    -- Đưa nhân vật đến mục tiêu (Sách hoặc Kệ)
    root.CFrame = CFrame.new(targetPos + Vector3.new(0, 1.5, 0))
    
    -- Chờ khoảng 1-2 khung hình rất nhỏ để Server ghi nhận gói tin vị trí (Bypass khoảng cách)
    task.wait(0.02)

    -- Thực hiện hành động (Grab hoặc Place)
    if actionCallback then
        actionCallback()
    end

    -- Trả ngay lập tức về vị trí ban đầu (Người khác sẽ không kịp nhìn thấy bạn dịch chuyển)
    root.CFrame = originalCFrame
end

-- 5. HÀM XỬ LÝ SONG SONG CHO TỪNG CUỐN SÁCH (INSTANT QUEUE)
local function queueProcessBook(book)
    if not book:IsA("BasePart") and not book:IsA("Model") then return end

    local name = book.Name
    local series, vol = name:match("^(.-)_(.+)$")
    local volNum = tonumber(vol)

    if not (series and volNum) then return end

    local genre, info = BooksData.GetCategory(series)
    if not (genre and info) then return end

    -- Tìm kệ thích hợp từ Cache dữ liệu
    for id, data in pairs(shelfDataCache) do
        if not data.Completed and data.Category == genre then
            local model = shelves[id]
            if model and model:GetAttribute("Width") == info.VolumeCount then
                
                -- Nếu kệ chưa có cuốn tập này, tiến hành xử lý
                if not data.Books[tostring(volNum)] then
                    
                    -- Tạo luồng chạy độc lập hoàn toàn (Xử lý song song giả lập)
                    task.spawn(function()
                        -- Bước 1: Ẩn danh tới nhặt sách
                        executeAtPosition(book:GetPivot().Position, function()
                            LibraryReplica:FireServer("Grab", book)
                        end)

                        -- Giãn cách siêu ngắn để tránh bị Server giới hạn packet (Rate Limit Remote)
                        task.wait(0.04)

                        -- Bước 2: Ẩn danh tới cất vào kệ
                        if getgenv().Running and shelves[id] then
                            executeAtPosition(shelves[id]:GetPivot().Position, function()
                                LibraryReplica:FireServer("Place", shelves[id], volNum - 1)
                            end)
                        end
                    end)

                    break -- Thoát vòng lặp tìm kệ cho cuốn sách này vì đã xếp lịch xong
                end
            end
        end
    end
end

-- 6. KÍCH HOẠT HỆ THỐNG CHẠY SONG SONG VÀ THEO DÕI AFK
task.spawn(function()
    print("[🔥] Khởi động Auto Farm Library Cao Cấp...")
    
    -- QUÉT TẤT CẢ SÁCH ĐANG CÓ SẴN (Instant Queue Toàn Bộ)
    local allBooks = BooksFolder:GetChildren()
    for _, book in ipairs(allBooks) do
        if not getgenv().Running then break end
        queueProcessBook(book)
        -- Tránh tụt FPS đột ngột nếu số lượng sách ban đầu quá lớn (>15 cuốn)
        if #allBooks > 15 then task.wait(0.01) end 
    end

    print("[⚡] Đã đưa tất cả sách vào hàng đợi! Đang trong trạng thái Auto AFK 24/7...")

    -- TỰ ĐỘNG XỬ LÝ KHI CÓ SÁCH MỚI SPAWN (Real-time Farm)
    local childAddedConnection
    childAddedConnection = BooksFolder.ChildAdded:Connect(function(newBook)
        if not getgenv().Running then
            childAddedConnection:Disconnect()
            return
        end
        -- Chờ một chút để thuộc tính CFrame của sách đồng bộ hẳn sang phía Client rồi nhặt
        task.delay(0.1, queueProcessBook, newBook)
    end)
end)
