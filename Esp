local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local LogService = game:GetService("LogService")

print("🔍 [Hệ thống]: Đang bật chế độ trinh sát... Hãy đi nhặt vài quả cầu bằng tay!")

-- Hàm tạo ra đoạn code hoàn chỉnh dựa trên dữ liệu phân tích được
local function GenerateFinalScript(parentName, sampleOrbName)
    local finalCode = [[
-- =======================================================
-- CODE TỰ ĐỘNG NHẶT QUẢ CẦU ĐÃ ĐƯỢC PHÂN TÍCH THÀNH CÔNG
-- =======================================================
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Tìm khu vực chứa quả cầu dựa trên phân tích
local TargetFolder = Workspace:FindFirstChild("%s", true) 
if not TargetFolder then 
    TargetFolder = Workspace -- Nếu không tìm thấy folder riêng, quét toàn bộ Workspace
end

local function getClosestOrb()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = character.HumanoidRootPart
    local closestOrb = nil
    local shortestDistance = math.huge

    for _, orb in ipairs(TargetFolder:GetDescendants()) do
        -- Kiểm tra đúng tên quả cầu đã phân tích: "%s"
        if orb:IsA("BasePart") and (orb.Name == "%s" or orb:FindFirstChildOfClass("TouchTransmitter")) then
            local distance = (hrp.Position - orb.Position).Magnitude
            if distance < shortestDistance and distance < 300 then -- Bán kính quét 300 mét
                shortestDistance = distance
                closestOrb = orb
            end
        end
    end
    return closestOrb
end

task.spawn(function()
    print("🚀 [Auto-Farm]: Đã kích hoạt chạy tự động!")
    while true do
        task.wait(0.1)
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        
        if humanoid and humanoid.Health > 0 then
            local targetOrb = getClosestOrb()
            if targetOrb then
                -- Bạn có thể đổi sang dịch chuyển (Teleport) bằng cách dùng: character.HumanoidRootPart.CFrame = targetOrb.CFrame
                humanoid:MoveTo(targetOrb.Position)
                repeat task.wait() until not targetOrb:IsDescendantOf(workspace) or (character.HumanoidRootPart.Position - targetOrb.Position).Magnitude < 3
            end
        end
    end
end)
]]
    -- Điền thông số phân tích vào chuỗi code
    return string.format(finalCode, parentName, sampleOrbName, sampleOrbName)
end

-- Theo dõi va chạm của nhân vật để phân tích quả cầu
local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
character.DescendantAdded:Connect(function(descendant)
    if descendant:IsA("TouchTransmitter") then
        local part = descendant.Parent
        -- Loại bỏ các phần thân của nhân vật và mặt đất thông thường
        if part and part.Name ~= "Terrain" and not part:IsDescendantOf(character) then
            local parentFolder = part.Parent
            local parentName = parentFolder and parentFolder.Name or "Workspace"
            local orbName = part.Name
            
            print("=======================================================")
            print("🎯 ĐÃ PHÂN TÍCH ĐƯỢC CẤU TRÚC QUẢ CẦU VỪA CHẠM VÀO:")
            print(" - Tên quả cầu (Orb Name): " .. orbName)
            print(" - Nằm trong Thư mục (Folder): " .. parentName)
            print("=======================================================")
            print("👇 ĐOẠN CODE HOÀN CHỈNH CỦA BẠN ĐỂ SAO CHÉP DƯỚI ĐÂY: 👇")
            
            -- Xuất code ra Console
            print(GenerateFinalScript(parentName, orbName))
            print("=======================================================")
        end
    end
end)
