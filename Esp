local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

-- Biến trạng thái toàn cục
_G.BlinkFarmEnabled = true
local MaxDistance = 250 -- Bán kính quét

----------------------------------------------------------------
-- UI: NÚT ON/OFF NHỎ GỌN (BẤM LÀ NGẮT/BẬT LẬP TỨC)
----------------------------------------------------------------
if CoreGui:FindFirstChild("BlinkFarmGui") then
    CoreGui.BlinkFarmGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "BlinkFarmGui"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

local ToggleButton = Instance.new("TextButton")
ToggleButton.Name = "ToggleButton"
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 65, 0, 30)
ToggleButton.Position = UDim2.new(0, 10, 0, 50)
ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
ToggleButton.Text = "BLINK: ON"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 13

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 6)
UICorner.Parent = ToggleButton

-- Kéo thả nút
local UserInputService = game:GetService("UserInputService")
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end
ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true dragStart = input.Position startPos = ToggleButton.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
ToggleButton.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
UserInputService.InputChanged:Connect(function(input) if input == dragInput and dragging then update(input) end end)

-- Bấm nút
ToggleButton.MouseButton1Click:Connect(function()
    _G.BlinkFarmEnabled = not _G.BlinkFarmEnabled
    if _G.BlinkFarmEnabled then
        ToggleButton.Text = "BLINK: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    else
        ToggleButton.Text = "BLINK: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
    end
end)

----------------------------------------------------------------
-- LOGIC KIỂM TRA VÀ TÌM QUẢ CẦU
----------------------------------------------------------------
local function isOrb(object)
    if object:IsA("BasePart") and not object:IsDescendantOf(LocalPlayer.Character) then
        local nameLower = string.lower(object.Name)
        if nameLower ~= "baseplate" and nameLower ~= "terrain" and nameLower ~= "field" and object.CanTouch == true then
            if object:FindFirstChildOfClass("TouchTransmitter") or object.Parent.Name:match("Orb") or object.Name:match("Orb") or object.Name:match("Star") then
                return true
            end
        end
    end
    return false
end

-- Hàm tìm nhanh 1 quả cầu gần nhất để xử lý lập tức thay vì ôm đồm cả rổ
local function getTargetOrb(pos)
    local closestOrb = nil
    local shortestDistance = MaxDistance

    for _, object in ipairs(Workspace:GetDescendants()) do
        if isOrb(object) and object:IsDescendantOf(Workspace) then
            local distance = (pos - object.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestOrb = object
            end
        end
    end
    return closestOrb
end

----------------------------------------------------------------
-- VÒNG LẶP CHÍNH (WHILE TRUE CHẠY VÔ HẠN)
----------------------------------------------------------------
task.spawn(function()
    print(" [Blink-Farm]: Đã sửa lỗi loop - Hệ thống bắt đầu farm liên tục!")
    
    while true do
        task.wait(0.01) -- Reset vòng quét cực nhanh sau 0.01 giây
        
        if _G.BlinkFarmEnabled then
            local character = LocalPlayer.Character
            local hrp = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if hrp and humanoid and humanoid.Health > 0 then
                local originalCFrame = hrp.CFrame
                
                -- Tìm đúng 1 mục tiêu gần nhất
                local target = getTargetOrb(originalCFrame.Position)
                
                if target then
                    -- Tốc biến đến ăn rồi về luôn trong chớp mắt
                    hrp.CFrame = target.CFrame
                    task.wait(0.01) -- Chờ server nhận diện
                    hrp.CFrame = originalCFrame
                    task.wait(0.01) -- Giãn cách chống crash game
                end
            end
        end
    end
end)
