-- [[ CẤU HÌNH VỪA PHẢI ]]
local WALK_SPEED = 32 -- Tốc độ mặc định của Roblox là 16. Mức 32 là vừa phải, khó bị anti-cheat phát hiện tự động.

-- [[ HÀM TẠO ESP TRONG SUỐT ]]
local function createESP(player)
    if player == game.Players.LocalPlayer then return end

    local function applyESP(character)
        if not character then return end
        -- Chờ HumanoidRootPart xuất hiện
        local hrp = character:WaitForChild("HumanoidRootPart", 10)
        if not hrp then return end

        -- Xóa ESP cũ nếu có để tránh trùng lặp khi người chơi hồi sinh
        if hrp:FindFirstChild("HighlightESP") then
            hrp.HighlightESP:Destroy()
        end

        -- Tạo Highlight (Viền và màu phủ lên người chơi)
        local highlight = Instance.new("Highlight")
        highlight.Name = "HighlightESP"
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Màu đỏ trong suốt
        highlight.FillTransparency = 0.5 -- Độ mờ bên trong
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng
        highlight.OutlineTransparency = 0 -- Hiện rõ viền
        highlight.Adornee = character
        highlight.Parent = hrp
    end

    -- Áp dụng khi nhân vật tải xong
    if player.Character then
        applyESP(player.Character)
    end
    player.CharacterAdded:Connect(applyESP)
end

-- [[ HÀM TĂNG TỐC ĐỘ CHẠY TỰ ĐỘNG ]]
local function loopSpeed()
    game:GetService("RunService").Heartbeat:Connect(function()
        pcall(function()
            local localPlayer = game.Players.LocalPlayer
            if localPlayer and localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") then
                localPlayer.Character.Humanoid.WalkSpeed = WALK_SPEED
            end
        end)
    end)
end

-- [[ KHỞI CHẠY VÀ CẬP NHẬT KHI ĐỔI SERVER / NGƯỜI CHƠI MỚI ]]
-- Quét toàn bộ người chơi hiện tại trong server
for _, player in ipairs(game.Players:GetPlayers()) do
    createESP(player)
end

-- Tự động áp dụng ESP cho người chơi mới tham gia server
game.Players.PlayerAdded:Connect(createESP)

-- Kích hoạt vòng lặp giữ tốc độ chạy
loopSpeed()

print("--- ESP & Speed đã được kích hoạt thành công ---")
